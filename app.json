{
  "expo": {
    "name": "VizMinder",
    "slug": "vizminder-a4",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "vizminder",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6200EE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "VizMinder uses photos as visual reminder cues.",
        "NSPhotoLibraryUsageDescription": "VizMinder lets users choose reminder images.",
        "NSLocationWhenInUseUsageDescription": "VizMinder uses location to support context-aware reminders."
      }
    },
    "android": {
      "package": "com.ezn24.vizmindera4",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-system-ui",
      "expo-sqlite",
      "expo-location",
      "expo-notifications",
      "expo-image-picker",
      "expo-background-task",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "firebaseApiKey": "",
      "firebaseAuthDomain": "",
      "firebaseProjectId": "",
      "firebaseStorageBucket": "",
      "firebaseMessagingSenderId": "",
      "firebaseAppId": ""
    }
  }
}
